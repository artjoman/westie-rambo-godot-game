; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Rambo Westie"
run/main_scene="res://scenes/ui/main_menu.tscn"
config/features=PackedStringArray("4.7", "GL Compatibility")
boot_splash/bg_color=Color(0, 0, 0, 1)
config/icon="res://assets/icon/icon_main_192.png"

[autoload]

GameState="*res://autoload/game_state.gd"
SaveManager="*res://autoload/save_manager.gd"
SceneManager="*res://autoload/scene_manager.gd"
AudioManager="*res://autoload/audio_manager.gd"
MusicManager="*res://autoload/music_manager.gd"
AchievementManager="*res://autoload/achievement_manager.gd"
CheatManager="*res://autoload/cheat_manager.gd"

[display]

window/size/viewport_width=480
window/size/viewport_height=270
window/size/window_width_override=1440
window/size/window_height_override=810
window/stretch/mode="viewport"
window/handheld/orientation="landscape"

